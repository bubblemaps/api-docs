{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Bubblemaps B2B",
  "colors": {
    "primary": "#6d30b9",
    "light": "#9560d5",
    "dark": "#561e9b"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://v2.bubblemaps.io",
          "icon": "chart-network"
        }
      ]
    },
    "groups": [
      {
        "group": "Get Started",
        "pages": ["introduction"]
      },
      {
        "group": "iFrame Integration",
        "pages": [
          "iframe/introduction",
          "iframe/demo",
          "iframe/quickstart",
          "iframe/pricing"
        ],
        "icon": "frame"
      },
      {
        "group": "Data API [Beta]",
        "pages": [
          "data/api/introduction",
          "data/api/authentication",
          "data/api/token-model",
          "data/api/changelog",
          {
            "group": "Deprecated",
            "pages": [
              "data/api/deprecated/get-supported-chains",
              "data/api/deprecated/get-map-data"
            ]
          },
          {
            "group": "Chains",
            "expanded": true,
            "pages": [
              "data/api/chains/supported"
            ]
          },
          {
            "group": "Tokens",
            "expanded": true,
            "pages": [
              "data/api/tokens/map",
              "data/api/tokens/top-holders",
              "data/api/tokens/search",
              "data/api/tokens/metadata",
              "data/api/tokens/metadata-batch"
            ]
          },
          {
            "group": "Addresses",
            "expanded": true,
            "pages": [
              "data/api/addresses/metadata",
              "data/api/addresses/metadata-batch"
            ]
          },
          {
            "group": "Relationships",
            "expanded": true,
            "pages": [
              "data/api/relationships/subgraph"
            ]
          }
        ],
        "icon": "database"
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "footer": {
    "socials": {
      "x": "https://x.com/bubblemaps",
      "telegram": "https://t.me/bubblemaps",
      "discord": "https://discord.gg/Sm6PJxwaqy"
    }
  },
  "css": "/custom.css"
}
